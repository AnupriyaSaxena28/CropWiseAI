# Copy to your shell env or an .env loader. All are optional — the app runs with
# graceful fallbacks/mock data when a key is missing.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# data.gov.in mandi prices (a public sample key is used if unset)
MARKET_API_KEY=

# Sarvam AI Indic audio (TTS/STT). STT returns a mock transcript when unset.
SARVAM_API_KEY=

# Neo4j AuraDB sustainability knowledge graph (optional)
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Security
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# Database (defaults to in-memory H2). For Postgres:
# DB_URL=jdbc:postgresql://localhost:5432/cropwise
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_DRIVER=org.postgresql.Driver
