# ── Google Gemini AI ─────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# ── Sarvam AI (Voice Chat) ───────────────────────────────────────
# Get from: https://platform.sarvam.ai/
SARVAM_API_KEY="your_sarvam_api_key_here"

# ── Neo4j (Sustainability Knowledge Graph) ───────────────────────
# Get from: https://neo4j.com/cloud/aura/
NEO4J_URI="neo4j+s://your_neo4j_uri_here"
NEO4J_USER="your_neo4j_username"
NEO4J_PASSWORD="your_neo4j_password"

# ── Firebase Client SDK (public — safe for browser) ──────────────
NEXT_PUBLIC_FIREBASE_API_KEY="your_firebase_api_key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your_project_id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your_project_id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your_project_id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your_sender_id"
NEXT_PUBLIC_FIREBASE_APP_ID="your_app_id"

# ── Firebase Admin SDK (server-only — never expose) ───────────────
FIREBASE_ADMIN_PROJECT_ID="your_project_id"
FIREBASE_ADMIN_CLIENT_EMAIL="firebase-adminsdk@your_project_id.iam.gserviceaccount.com"
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Market Prices: data.gov.in Agmarknet API (real mandi prices) ──
# Register (free) → https://data.gov.in/user/register
# Then copy your key from your profile page (https://data.gov.in/me).
# If left unset, a shared public sample key is used (rate-limited; dev only).
MARKET_API_KEY="your_data_gov_in_api_key"

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
